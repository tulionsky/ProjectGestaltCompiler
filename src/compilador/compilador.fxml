<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="compilador.CompiladorController"
      style="-fx-background-color: #1e1e2e;"
      prefWidth="1150" prefHeight="780">

    <!-- Barra de título -->
    <HBox style="-fx-background-color: #11111b; -fx-padding: 12 16;"
          spacing="10" alignment="CENTER_LEFT">
        <FontIcon iconLiteral="mdi2s-sword-cross"
                  iconSize="22"
                  iconColor="#cba6f7"/>
        <Label text="Project Gestalt — Compilador NieR"
               style="-fx-text-fill: #cba6f7; -fx-font-size: 16px;
                      -fx-font-weight: bold;"/>
    </HBox>

    <!-- Editor y árbol -->
    <SplitPane VBox.vgrow="ALWAYS" dividerPositions="0.5"
               style="-fx-background-color: #1e1e2e; -fx-border-color: transparent;">

        <!-- Panel editor -->
        <VBox style="-fx-background-color: #1e1e2e;">
            <HBox style="-fx-background-color: #313244; -fx-padding: 5 10;"
                  spacing="8" alignment="CENTER_LEFT">
                <FontIcon iconLiteral="mdi2n-note-edit-outline"
                          iconSize="16" iconColor="#89b4fa"/>
                <Label text="Editor de Código"
                       style="-fx-text-fill: #89b4fa; -fx-font-weight: bold;"/>
            </HBox>
            <TextArea fx:id="editorCodigo" VBox.vgrow="ALWAYS"
                      promptText="// Escribe tu código Project Gestalt aquí..."
                      style="-fx-control-inner-background: #1e1e2e;
                             -fx-text-fill: #cdd6f4;
                             -fx-font-family: 'JetBrains Mono', Consolas, monospace;
                             -fx-font-size: 14px;
                             -fx-border-color: transparent;"/>
        </VBox>

        <!-- Panel árbol -->
        <VBox style="-fx-background-color: #1e1e2e;">
            <HBox style="-fx-background-color: #313244; -fx-padding: 5 10;"
                  spacing="8" alignment="CENTER_LEFT">
                <FontIcon iconLiteral="mdi2s-source-tree"
                          iconSize="16" iconColor="#a6e3a1"/>
                <Label text="Árbol Sintáctico"
                       style="-fx-text-fill: #a6e3a1; -fx-font-weight: bold;"/>
            </HBox>
            <TextArea fx:id="areaResultado" VBox.vgrow="ALWAYS"
                      editable="false"
                      style="-fx-control-inner-background: #181825;
                             -fx-text-fill: #a6e3a1;
                             -fx-font-family: 'JetBrains Mono', Consolas, monospace;
                             -fx-font-size: 13px;
                             -fx-border-color: transparent;"/>
        </VBox>

    </SplitPane>

    <!-- Barra de botones -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: #181825; -fx-padding: 10 14;">

        <Button onAction="#ejecutarAnalisis"
                style="-fx-background-color: #a6e3a1; -fx-text-fill: #1e1e2e;
                       -fx-font-weight: bold; -fx-font-size: 13px;
                       -fx-padding: 8 16; -fx-background-radius: 8;
                       -fx-cursor: hand;">
            <graphic>
                <HBox spacing="6" alignment="CENTER">
                    <FontIcon iconLiteral="mdi2p-play-circle-outline"
                              iconSize="16" iconColor="#1e1e2e"/>
                    <Label text="Analizar" style="-fx-font-weight: bold;
                                                  -fx-text-fill: #1e1e2e;"/>
                </HBox>
            </graphic>
        </Button>

        <Button onAction="#limpiar"
                style="-fx-background-color: #f38ba8; -fx-text-fill: #1e1e2e;
                       -fx-font-weight: bold; -fx-font-size: 13px;
                       -fx-padding: 8 16; -fx-background-radius: 8;
                       -fx-cursor: hand;">
            <graphic>
                <HBox spacing="6" alignment="CENTER">
                    <FontIcon iconLiteral="mdi2t-trash-can-outline"
                              iconSize="16" iconColor="#1e1e2e"/>
                    <Label text="Limpiar" style="-fx-font-weight: bold;
                                                 -fx-text-fill: #1e1e2e;"/>
                </HBox>
            </graphic>
        </Button>

        <Button onAction="#cargarEjemplo"
                style="-fx-background-color: #89b4fa; -fx-text-fill: #1e1e2e;
                       -fx-font-weight: bold; -fx-font-size: 13px;
                       -fx-padding: 8 16; -fx-background-radius: 8;
                       -fx-cursor: hand;">
            <graphic>
                <HBox spacing="6" alignment="CENTER">
                    <FontIcon iconLiteral="mdi2c-code-braces"
                              iconSize="16" iconColor="#1e1e2e"/>
                    <Label text="Ejemplo" style="-fx-font-weight: bold;
                                                 -fx-text-fill: #1e1e2e;"/>
                </HBox>
            </graphic>
        </Button>

        <!-- Separador -->
        <Pane HBox.hgrow="ALWAYS"/>

        <FontIcon iconLiteral="mdi2i-information-outline"
                  iconSize="16" iconColor="#6c7086"/>
        <Label fx:id="labelEstado" text="Listo"
               style="-fx-text-fill: #a6e3a1; -fx-font-size: 13px;"/>

    </HBox>

    <!-- Tablas -->
    <SplitPane prefHeight="230" dividerPositions="0.58"
               style="-fx-background-color: #1e1e2e;">

        <!-- Tabla tokens -->
        <VBox style="-fx-background-color: #1e1e2e;">
            <HBox style="-fx-background-color: #313244; -fx-padding: 5 10;"
                  spacing="8" alignment="CENTER_LEFT">
                <FontIcon iconLiteral="mdi2t-tag-multiple-outline"
                          iconSize="16" iconColor="#f9e2af"/>
                <Label text="Tabla de Tokens"
                       style="-fx-text-fill: #f9e2af; -fx-font-weight: bold;"/>
            </HBox>
            <TableView fx:id="tablaTokens" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #181825;">
                <columns>
                    <TableColumn fx:id="colNo"      text="#"
                                 prefWidth="45"/>
                    <TableColumn fx:id="colToken"   text="Token"
                                 prefWidth="140"/>
                    <TableColumn fx:id="colTipo"    text="Tipo"
                                 prefWidth="180"/>
                    <TableColumn fx:id="colLinea"   text="Línea"
                                 prefWidth="60"/>
                    <TableColumn fx:id="colColumna" text="Columna"
                                 prefWidth="75"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>

        <!-- Tabla errores -->
        <VBox style="-fx-background-color: #1e1e2e;">
            <HBox style="-fx-background-color: #313244; -fx-padding: 5 10;"
                  spacing="8" alignment="CENTER_LEFT">
                <FontIcon iconLiteral="mdi2a-alert-circle-outline"
                          iconSize="16" iconColor="#f38ba8"/>
                <Label text="Tabla de Errores"
                       style="-fx-text-fill: #f38ba8; -fx-font-weight: bold;"/>
            </HBox>
            <TableView fx:id="tablaErrores" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #181825;">
                <columns>
                    <TableColumn fx:id="colETipo"  text="Tipo"
                                 prefWidth="90"/>
                    <TableColumn fx:id="colELinea" text="Línea"
                                 prefWidth="55"/>
                    <TableColumn fx:id="colECol"   text="Columna"
                                 prefWidth="70"/>
                    <TableColumn fx:id="colEDesc"  text="Descripción"
                                 prefWidth="300"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>

    </SplitPane>

</VBox>